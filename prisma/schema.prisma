// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Students {
  id            String   @id @default(uuid())
  matricNumber  String   @unique
  email         String   @unique
  name          String?
  password      String
  createdAt     DateTime @default(now())
  enrollments   Enrollment[]
  submissions  Submission[]
}

model Instructors {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  password      String
  createdAt     DateTime @default(now())
  courses       Courses[]
}

model Courses {
  id            String   @id @default(uuid())
  courseCode    String   @unique
  courseName    String
  instructorId  String
  createdAt     DateTime @default(now())
  enrollments   Enrollment[]
  assignments  Assignments[]

  instructor    Instructors @relation(fields: [instructorId], references: [id])  
}

model Enrollment {
  id            String  @id @default(uuid())
  studentId     String
  courseId      String
  enrolledAt    DateTime @default(now())

  students      Students @relation(fields: [studentId], references: [id])
  courses       Courses @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model Assignments {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String
  deadline    DateTime
  createdAt   DateTime @default(now())
  submissions  Submission[]

  course      Courses  @relation(fields: [courseId], references: [id])
}

model Submission {
  id           String      @id @default(uuid())
  studentId    String
  assignmentId String
  zipPath      String
  submittedAt  DateTime    @default(now())
  aiScore      Int?
  aiFeedback   String?
  finalScore   Int?

  student      Students    @relation(fields: [studentId], references: [id])
  assignment   Assignments @relation(fields: [assignmentId], references: [id])

  @@unique([studentId, assignmentId])
}